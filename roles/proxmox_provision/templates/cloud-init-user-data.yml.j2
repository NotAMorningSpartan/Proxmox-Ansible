#cloud-config
# Cloud-init user-data for {{ vm_name }}
# Generated by the proxmox_provision Ansible role

# Set the hostname
hostname: {{ vm_name.split('.')[0] }}
fqdn: {{ vm_name }}
manage_etc_hosts: true

# Enable SSH password authentication
ssh_pwauth: true

# User accounts
users:
  - name: root
    lock_passwd: false
  - name: {{ admin_user }}
    gecos: Ansible Admin User
    groups: wheel
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
{% if admin_ssh_pubkey | default('') | length > 0 %}
    ssh_authorized_keys:
      - {{ admin_ssh_pubkey }}
{% endif %}

# Set passwords for root and admin user
chpasswd:
  expire: false
  users:
    - name: root
      password: {{ root_password }}
      type: text
    - name: {{ admin_user }}
      password: {{ admin_password }}
      type: text

# Disable root SSH with key only (password set above, SSH via admin user preferred)
disable_root: false
