---
# Vault secrets template
#
# 1. Copy this file:
#      cp vault/secrets.yml.example vault/secrets.yml
#
# 2. Edit vault/secrets.yml with your real credentials.
#
# 3. Encrypt it:
#      ansible-vault encrypt vault/secrets.yml
#
# 4. Reference at runtime:
#      ansible-playbook playbooks/site.yml \
#        -e @vars/myvm.yml \
#        -e @vault/secrets.yml \
#        --ask-vault-pass
#
# The vault/secrets.yml file is excluded from git via .gitignore.

# --- Proxmox API ---
# Token secret from Datacenter > Permissions > API Tokens
# Referenced as {{ vault_proxmox_api_token_secret }} in group_vars/proxmox.yml
vault_proxmox_api_token_secret: "CHANGEME-your-proxmox-api-token-secret"

# --- VM Passwords (cloud-init) ---
root_password: "CHANGEME-root-password"
admin_password: "CHANGEME-admin-password"

# --- Red Hat Subscription Manager ---
# Only needed if using username/password mode (not activation key mode)
rhsm_username: "CHANGEME-redhat-username"
rhsm_password: "CHANGEME-redhat-password"

# --- Red Hat IdM ---
# Password for the enrollment principal (default: admin)
idm_admin_password: "CHANGEME-idm-admin-password"
